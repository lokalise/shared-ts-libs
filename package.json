{
  "name": "shared-ts-libs",
  "private": true,
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22.0.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.0.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "clean": "turbo run clean",
    "build": "turbo run build",
    "test:ci": "turbo run test:ci",
    "lint": "turbo run lint --continue=always",
    "lint:fix": "turbo run lint:fix --continue=always"
  },
  "devDependencies": {
    "turbo": "^2.4.4"
  }
}
