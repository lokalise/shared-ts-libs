// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider     = "cockroachdb"
  relationMode = "prisma"
}

generator client {
  provider = "prisma-client"
  output   = "../node_modules/db-client"
}

model Item1 {
  id    String @id @unique @default(dbgenerated("gen_random_ulid()")) @db.Uuid
  value String

  @@map("item1")
}

model Item2 {
  id    String @id @unique @default(dbgenerated("gen_random_ulid()")) @db.Uuid
  value String

  @@map("item2")
}

model BulkUpdateItem {
  id       String @id @default(dbgenerated("gen_random_ulid()")) @db.Uuid
  groupId  String @map("group_id") @db.Uuid
  number   Int    @default(0)
  value    String
  count    Int?
  metadata Json?

  @@unique([groupId, number])
  @@map("bulk_update_item")
}
