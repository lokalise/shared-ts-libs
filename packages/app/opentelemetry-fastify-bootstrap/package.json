{
    "name": "@lokalise/opentelemetry-fastify-bootstrap",
    "version": "3.1.0",
    "type": "module",
    "files": [
        "dist",
        "README.md",
        "LICENSE.md"
    ],
    "license": "Apache-2.0",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": "./dist/index.js",
        "./package.json": "./package.json"
    },
    "keywords": [
        "opentelemetry",
        "otel",
        "fastify",
        "tracing",
        "instrumentation",
        "bootstrap"
    ],
    "homepage": "https://github.com/lokalise/shared-ts-libs",
    "repository": {
        "type": "git",
        "url": "git://github.com/lokalise/shared-ts-libs.git",
        "directory": "packages/app/opentelemetry-fastify-bootstrap"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "rimraf dist && tsc --project tsconfig.build.json",
        "lint": "biome check . && tsc",
