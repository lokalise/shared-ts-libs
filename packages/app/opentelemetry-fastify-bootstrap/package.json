        "test": "vitest run",
        "test:ci": "pnpm run test -- --coverage",
        "prepublishOnly": "pnpm run build",
        "package-version": "echo $npm_package_version",
        "postversion": "biome check --write package.json"
    },
    "dependencies": {},
    "peerDependencies": {
        "@fastify/otel": "0.19.0",
        "@opentelemetry/auto-instrumentations-node": "^0.77.0",
