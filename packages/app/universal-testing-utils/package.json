{
    "name": "@lokalise/universal-testing-utils",
    "version": "3.8.0",
    "files": [
        "dist"
    ],
    "license": "Apache-2.0",
    "type": "module",
    "main": "./dist/index.js",
    "enableTransparentWorkspaces": "false",
    "homepage": "https://github.com/lokalise/shared-ts-libs",
    "repository": {
        "type": "git",
        "url": "git://github.com/lokalise/shared-ts-libs.git",
        "directory": "packages/app/universal-testing-utils"
    },
    "exports": {
        ".": "./dist/index.js",
        "./package.json": "./package.json"
    },
    "private": false,
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "api",
        "contracts",
        "contract",
        "testing",
        "mocking",
        "msw",
        "mock",
        "server",
        "frontend",
        "universal"
    ],
    "scripts": {
        "build": "rimraf dist && tsc --project tsconfig.build.json",
        "lint": "biome check . && tsc",
        "lint:fix": "biome check --write",
        "test": "vitest run",
        "test:ci": "vitest run --coverage",
        "prepublishOnly": "pnpm run build",
        "package-version": "echo $npm_package_version",
        "postversion": "biome check --write package.json"
    },
    "peerDependencies": {
        "@lokalise/api-contracts": ">=6.13.0",
        "mockttp": ">=4.2.1",
        "msw": ">=2.7.0",
        "zod": ">=3.25.56"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.0",
        "@lokalise/api-contracts": "workspace:^",
        "@lokalise/biome-config": "workspace:^",
        "@lokalise/frontend-http-client": "workspace:^",
        "@lokalise/tsconfig": "workspace:^",
        "@vitest/coverage-v8": "^4.1.9",
        "mockttp": "^4.4.2",
        "msw": "^2.13.2",
        "rimraf": "^6.0.1",
        "typescript": "6.0.3",
        "vitest": "^4.1.9",
        "wretch": "^3.0.8",
        "zod": "^4.3.6"
    },
    "dependencies": {}
}
