        "dist/**",
        "LICENSE.md",
        "README.md"
    ],
    "type": "module",
    "main": "./dist/index.js",
    "exports": {
        ".": "./dist/index.js",
        "./package.json": "./package.json"
    },
    "homepage": "https://github.com/lokalise/shared-ts-libs",
